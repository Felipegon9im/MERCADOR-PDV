{
  "name": "mercado-pdv",
  "version": "1.0.4",
  "description": "Sistema PDV Completo e Offline-First para Mercado e Conveniência",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && electron .",
    "build:renderer": "vite build",
    "build:electron": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "pdv",
    "electron",
    "react",
    "sqlite",
    "offline-first"
  ],
  "author": "Antigravity",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "canvas-confetti": "^1.9.3",
    "chart.js": "^4.4.2",
    "fast-xml-parser": "^4.3.6",
    "lucide-react": "^0.368.0",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "wait-on": "^9.0.0"
  },
  "build": {
    "appId": "com.mercadopdv.app",
    "productName": "MercadoPDV",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "database.js",
      "package.json",
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    }
  }
}
